NODE_ENV=development
APP_NAME=My App
JWT_SECRET=replace-with-strong-random-string
DATABASE_PROVIDER=supabase   # or mongodb or firebase

# Email (required for OTP)
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587               # 465 for SSL
EMAIL_USER=placeholder@example.com
EMAIL_PASS=yourpassword
EMAIL_FROM=no-reply@example.com

# Supabase (if DATABASE_PROVIDER=supabase)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_SERVICE_KEY=service_role_key

# MongoDB (if DATABASE_PROVIDER=mongodb)
MONGODB_URI=mongodb+srv://user:pass@cluster0.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB_NAME=db_name

# Firebase Admin (if DATABASE_PROVIDER=firebase)
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nABC...\n-----END PRIVATE KEY-----\n"

# Defense service (Python) - Dual-LLM Prompt Injection Defense
DEFENSE_SERVICE_URL=http://localhost:5000

# LLM mode: lmstudio | transformers (Windows-friendly, no vLLM)
# lmstudio: Use LM Studio local servers (OpenAI-compatible API)
# transformers: Run models in-process with Hugging Face Transformers
LLM_MODE=lmstudio

# === LM Studio mode (LLM_MODE=lmstudio) ===
# Start LM Studio, load a model, enable "Local Server" (port 1234).
# Optional: second LM Studio instance on 1235 for shadow. If only one server,
# both Primary and Shadow run on the same base_url with different model names.
PRIMARY_BASE_URL=http://localhost:1234/v1
SHADOW_BASE_URL=http://localhost:1235/v1
PRIMARY_MODEL=your-primary-model
SHADOW_MODEL=your-shadow-model

# === Transformers mode (LLM_MODE=transformers) ===
# Run models in-process. Python 3.11 recommended. Falls back to CPU if CUDA unavailable.
# MODEL_DEVICE=cuda
MODEL_DEVICE=cpu

# === Fallback: Hugging Face + OpenAI (comment out PRIMARY_BASE_URL) ===
# HF_TOKEN=hf_xxxx
# PRIMARY_MODEL=facebook/Meta-SecAlign-8B
# SHADOW_MODEL=gpt-4o-mini
# OPENAI_API_KEY=sk-proj-xxxx

THRESH_LOW=0.25
THRESH_HIGH=0.55
THRESH_CRITICAL=0.75
INPUT_MAX_CHARS=20000
RATE_LIMIT_CHAT_PER_MIN=30

# Optional: protect /debug/llm endpoint with X-Debug-Key header
# DEBUG_LLM_KEY=your-secret-key

# LLM timeouts (seconds); 0 = no timeout
LLM_CONNECT_TIMEOUT=15
LLM_READ_TIMEOUT=120
# Health check cache TTL (seconds)
HEALTH_CACHE_TTL=30

# Cloudinary
CLOUDINARY_CLOUD_NAME=abcde0abc
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=